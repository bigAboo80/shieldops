FROM golang:1.24-bookworm

# Системные зависимости
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    openssh-server \
    postgresql-client \
    make \
    gcc \
    sudo \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS (для Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# golangci-lint
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/HEAD/install.sh | \
    sh -s -- -b /usr/local/bin v1.64.0

# aider для работы с Ollama/Qwen
RUN pip3 install --break-system-packages aider-chat 2>/dev/null || \
    (apt-get update && apt-get install -y python3-pip && \
     pip3 install --break-system-packages aider-chat)

# Пользователь dev (не root)
RUN useradd -m -s /bin/bash -G sudo dev \
    && echo "dev ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# SSH сервер для удалённого доступа
RUN mkdir -p /var/run/sshd \
    && echo "PermitRootLogin no" >> /etc/ssh/sshd_config \
    && echo "PasswordAuthentication no" >> /etc/ssh/sshd_config \
    && echo "PubkeyAuthentication yes" >> /etc/ssh/sshd_config

# Go environment
ENV GOPATH=/home/dev/go
ENV PATH=$GOPATH/bin:/usr/local/go/bin:$PATH

USER dev
WORKDIR /workspace

# Скрипт для подключения к Ollama
RUN echo '#!/bin/bash\n\
echo "=== ShieldOps Dev Environment ==="\n\
echo "Go:        $(go version)"\n\
echo "Node:      $(node --version)"\n\
echo "Claude:    $(claude --version 2>/dev/null || echo not configured)"\n\
echo "Ollama:    ${OLLAMA_HOST:-not set}"\n\
echo "Workspace: /workspace"\n\
echo ""\n\
echo "Quick commands:"\n\
echo "  claude              — Claude Code CLI (Sonnet)"\n\
echo "  make build          — собрать ShieldOps"\n\
echo "  make test           — запустить тесты"\n\
echo "  aider --model openai/qwen3-coder:30b --openai-api-base $OLLAMA_HOST/v1 --openai-api-key x"\n\
echo "================================="' > /home/dev/welcome.sh \
    && chmod +x /home/dev/welcome.sh \
    && echo "source ~/welcome.sh" >> /home/dev/.bashrc

# Entrypoint: SSH + shell
COPY --chown=dev:dev entrypoint.sh /home/dev/entrypoint.sh

ENTRYPOINT ["/home/dev/entrypoint.sh"]
CMD ["bash"]
